<cache-config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xmlns="http://xmlns.oracle.com/coherence/coherence-cache-config"
              xsi:schemaLocation="http://xmlns.oracle.com/coherence/coherence-cache-config coherence-cache-config.xsd">

  <caching-scheme-mapping>
    <cache-mapping>
      <cache-name>journal-store-compatibility</cache-name>
      <scheme-name>journal-store-compatibility</scheme-name>
    </cache-mapping>
  </caching-scheme-mapping>

  <caching-schemes>
    <distributed-scheme>
      <scheme-name>journal-store-compatibility</scheme-name>
      <service-name>JournalStoreCompatibilityService</service-name>
      <thread-count-min system-property="test.threads">0</thread-count-min>
      <partition-count system-property="coherence.distributed.partitions">257</partition-count>
      <backup-count system-property="test.backupcount">1</backup-count>
      <backing-map-scheme>
        <journal-scheme/>
      </backing-map-scheme>
      <persistence>
        <environment system-property="test.persistent-environment">simple-journal-environment</environment>
      </persistence>
      <partitioned-quorum-policy-scheme>
        <class-name>persistence.AbstractSimplePersistenceTests$QuorumPolicy</class-name>
      </partitioned-quorum-policy-scheme>
      <autostart>true</autostart>
      <async-backup system-property="test.asyncbackup">false</async-backup>
    </distributed-scheme>
  </caching-schemes>
</cache-config>
