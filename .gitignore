# used by intellij
# ignore these types of java files
*.class
*.jar
*.war
*.rar
*.gar
*.log

# ignore these IntelliJ files
.idea
*.iml
*.ipr
*.iws

# ignore these hidden and build specific files
.*
~*

# ignore these folders
target
dist
_package
build/
node_modules/
prj/demo/unified-persistence-explorer/runtime/

#ignore these specific files
dependency-reduced-pom.xml
.flattened-pom.xml

# however allow these files
!.ignore
!.github
!.gitignore
!.ai
!.ai/**
!prj/.ai
!prj/.ai/**
!prj/.mvn
!prj/.mvn/**
!tools/**/*.jar
!tools/maven/boot/*.jar
!tools/maven/lib/*.jar

# ignore local AI runtime artifacts but keep committed context/docs
.ai/runs/**
.ai/scratch/**
.ai/rq-monitor/**
prj/.ai/runs/**
prj/.ai/scratch/**
prj/.ai/rq-monitor/**
